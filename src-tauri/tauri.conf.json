{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PerfectFit",
  "mainBinaryName": "PerfectFit",
  "version": "1.3.1",
  "identifier": "com.redeemed3d.perfectfit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PerfectFit — Filament Calibration Wizard",
        "width": 1100,
        "height": 800,
        "minWidth": 700,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
